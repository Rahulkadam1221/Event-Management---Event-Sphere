# Railway Production environment variables template

# Server config
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://eventsphere.vercel.app

# Database (Neon PostgreSQL connection pooled URL)
DATABASE_URL=postgresql://user:pass@ep-pooler.neon.tech/eventsphere?sslmode=require
# Direct URL used for Prisma migrations (non-pooled connection string)
DIRECT_URL=postgresql://user:pass@ep-direct.neon.tech/eventsphere?sslmode=require

# Security Keys (JWT)
JWT_SECRET=generate-a-strong-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=generate-a-strong-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Mail Transport config (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=EventSphere <noreply@eventsphere.com>

# Razorpay payment keys
RAZORPAY_KEY_ID=rzp_live_yourKeyId
RAZORPAY_KEY_SECRET=yourRazorpayKeySecret

# API Rate Limit thresholds
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
